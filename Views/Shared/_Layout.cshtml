@using Microsoft.AspNetCore.Identity;
@using BelotWebApp.Data;

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover" />
    <link rel="manifest" href="~/manifest.json" asp-append-version="true">
    <meta name="theme-color" content="#000000">
    <link rel="shortcut icon" type="image/ico" href="~/images/NiobiumCrystal.ico">
    <title>@ViewData["Title"] - NiobiumFire</title>
    @* CSS *@
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/Global.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Assets.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BelotWebApp.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.css">
    @RenderSection("styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand navbar-dark box-shadow">
            <div class="container">
                <div class="d-flex justify-content-start align-items-center">
                    <img src="~/images/NiobiumCrystal.png" height="30" />
                    <ul class="navbar-nav d-flex align-items-center">
                        <li class="nav-item me-3">
                            <a class="navbar-brand mx-0 px-1" asp-controller="Home" asp-action="Index">NiobiumFire Jass</a>
                        </li>
                        @if (signInManager.IsSignedIn(User) && User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link mx-0 px-1" asp-controller="Administration" asp-action="Index">Admin</a>
                            </li>
                        }
                    </ul>
                </div>
                <partial name="_LoginPartial.cshtml" />
            </div>
        </nav>
    </header>
    <canvas class="nebula" id="nebula"></canvas>
    @RenderBody()

    <footer>
        <div class="container">
            &copy; 2026 - NiobiumFire - <a style="color:white" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/sw.js');
        }

        document.addEventListener('touchstart', function () { }, { passive: true }); // allow safari ios to register button active state
    </script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/Nebula.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
