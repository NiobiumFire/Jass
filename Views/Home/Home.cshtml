@using Microsoft.AspNetCore.Identity;

@section scripts {
    <script src="~/js/Belotlobby.js" asp-append-version="true"></script>
    <script src="~/js/FitCrystal.js" asp-append-version="true"></script>

    <script>
        $('.modal').on('hide.bs.modal', function () { // remove focus from modals before they are hidden to prevent aria warnings
            if (this.contains(document.activeElement)) {
                document.activeElement.blur();
            }
        });

        $(document).ready(function () {
            //$('#create-game-modal').modal('show');
        });
    </script>
}

@{
    bool isSignedIn = signInManager.IsSignedIn(User);
    bool emailConfirmed = User.IsInRole("Player");
    ViewData["Title"] = "Home";
}

<HeadContent>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Rye&display=swap" rel="stylesheet" />
</HeadContent>

<main>

    <div></div>

    <div class="d-flex justify-content-center align-items-center">
        <div class="d-grid parchment title-banner rounded" style="grid-template-columns: 4% 10% 72% 10% 4%;">
            <div></div>
            <div class="crystal-container crystal-container-left">
                @await Html.PartialAsync("_Crystal")
            </div>
            <div class="title-banner-text">
                Nio Jass
            </div>
            <div class="crystal-container crystal-container-right">
                @await Html.PartialAsync("_Crystal")
            </div>
            <div></div>
        </div>
    </div>

    @* <svg class="d-none">
    <filter id="wavy2">
    <feTurbulence x="0" y="0" baseFrequency="0.02" numOctaves="5" seed="1"></feTurbulence>
    <feDisplacementMap in="SourceGraphic" scale="20" />
    </filter>
    </svg> *@

    <div></div>

    <div class="welcome-text-container">
        <p>Welcome, @User.Identity?.Name</p>
        @if (!isSignedIn)
        {
            <p><a class="link" asp-page="/Account/Login">Log in</a> or <a class="link" asp-page="/Account/Register">register</a> for all features</p>
        }
        else if (!emailConfirmed)
        {
            <p><a class="link" asp-page="/Account/Email">Confirm your email</a> for all features</p>
        }
    </div>

    <div class="lower-section">

        <div></div>

        <div class="img-container">
            <img class="maximise-image character-left" src="~/images/Jack.png" />
        </div>

        <div class="menu-buttons-container">
            <div class="menu-buttons">

                <p class="my-1 my-sm-0" style="text-align:center; white-space:nowrap">◆ Ranked ◆</p>

                @if (!isSignedIn || !emailConfirmed)
                {
                    <span title="Sign into an account with a confirmed email address">
                        <button type="button" class="btn2" style="width: 100%" disabled>
                            Match <i class="bi bi-lock-fill"></i>
                        </button>
                    </span>
                }
                else
                {
                    <button type="button" class="btn2" style="width: 100%" onclick="populateLobby()" data-bs-toggle="modal" data-bs-target="#join-game-modal">
                        Match
                    </button>
                }

                <p class="my-1 my-sm-0" style="text-align:center; white-space:nowrap">◆ Casual ◆</p>

                <div class="btn-group casual-btn-group" style="width: 100%" role="group">
                    <button type="button" class="btn2" onclick="populateLobby()" data-bs-toggle="modal" data-bs-target="#join-game-modal">Lobby</button>
                    <button type="button" class="btn2" data-bs-toggle="modal" data-bs-target="#create-game-modal">Create</button>
                </div>

                <p class="my-1 my-sm-0" style="text-align:center; white-space:nowrap">◆ General ◆</p>

                <p class="mb-2 mb-sm-4"><button type="button" class="btn2" data-bs-toggle="modal" style="width: 100%" data-bs-target="#rulesModal">Rules</button></p>

                @if (!isSignedIn || !emailConfirmed)
                {
                    <span title="Sign into an account with a confirmed email address">
                        <p>
                            <button type="button" class="btn2 mb-2 mb-sm-4" style="width: 100%" disabled>
                                Replay <i class="bi bi-lock-fill"></i>
                            </button>
                        </p>
                    </span>
                }
                else
                {
                    <p>
                        <button type="button" class="btn2 mb-2 mb-sm-4" onclick="location.href='@Url.Action("Index", "Replay")'" style="width: 100%">
                            Replay
                        </button>
                    </p>
                }

                @if (await userManager.GetUserAsync(User) is ApplicationUser user && await userManager.IsInRoleAsync(user, "Admin"))
                {
                    <p><button type="button" onclick="location.href='/Training/Index'" class="btn2" style="width: 100%">Training Center</button></p>
                }

            </div>
        </div>

        <div class="img-container">
            <img class="maximise-image character-right" src="~/images/Nine.png" />
        </div>
        <div></div>
    </div>

</main>

<!-- Create Game Modal -->
@{
    var options = new BelotRoomCreationOptions
            {
                RoomName = $"{userManager.GetUserName(User)}'s room"
            };
}
<partial name="_CreateGameModal" model="options" />

<!-- Join Game Modal -->
<div class="modal join-game-modal" tabindex="-1" id="join-game-modal">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content parchment2">
            <div class="modal-header">
                <h5 class="modal-title">Casual rooms</h5>
                <div class="d-flex justify-content-center align-items-center">
                    <i class="bi bi-arrow-repeat form-btn" onclick="refreshLobby()" id="refreshBtn"></i>
                    <i class="bi bi-x-lg form-btn" data-bs-dismiss="modal"></i>
                </div>
            </div>
            <div class="modal-body px-0 px-sm-1">
                <table class="table m-0">
                    <tbody class="lobby-table" id="lobby-table"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Rules Modal -->
@await Html.PartialAsync("_JassRules")
