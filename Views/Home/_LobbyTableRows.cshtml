@using BelotWebApp.BelotClasses
@model List<BelotLobbyGame>

@functions {
    public string IsEmpty(string value) => value == "<empty>" ? "muted" : "";
}

@foreach (var room in Model)
{
    <tr>
        <td colspan="3">@(room.Started ? "Started" : "Not started")</td>
        <td style="text-align: center">
            <button class="w-100 bi bi-box-arrow-in-right py-1 px-1 btn2" onclick="window.location.href='@Url.Action("Index", "Room", new { id = room.RoomId })'">
                @* <i class="bi bi-box-arrow-in-right"></i> *@
            </button>
        </td>
    </tr>
    <tr>
        <td class="position-icon bi bi-arrow-left-circle @IsEmpty(room.West)"></td>
        <td class="position-icon bi bi-arrow-up-circle @IsEmpty(room.North)"></td>
        <td class="position-icon bi bi-arrow-right-circle @IsEmpty(room.East)"></td>
        <td class="position-icon bi bi-arrow-down-circle @IsEmpty(room.South)"></td>
    </tr>
    <tr>
        <td class="truncate-cell @IsEmpty(room.West)">@room.West</td>
        <td class="truncate-cell @IsEmpty(room.North)">@room.North</td>
        <td class="truncate-cell @IsEmpty(room.East)">@room.East</td>
        <td class="truncate-cell @IsEmpty(room.South)">@room.South</td>
    </tr>
}