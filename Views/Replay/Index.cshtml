@{
    ViewData["Title"] = "Replay";
}
@section scripts {
    <script src="~/js/belotreplayroom.js"></script>
    <script src="~/js/belotroomreplayshared.js"></script>
}

<main>
    <div class="board-container">
        <!-- Control Panel -->
        <div class="control-panel parchment">
            <!-- Load Game -->
            <div class="control-panel-section col-2 dropdown">
                <button class="btn2" data-bs-toggle="offcanvas" data-bs-target="#my-games" onclick="getMyReplays()">Load</button>
            </div>
            <!-- Replay Control -->
            <div class="control-panel-section col-8 d-flex justify-content-center">
                <button class="btn2" type="button" onclick="prev()" id="replay-prev" disabled>
                    <i class="bi bi-skip-backward-circle-fill" style="font-size:1.5em"></i>
                </button>
                <button class="btn2" type="button" onclick="back()" id="replay-back" disabled>
                    <i class="bi bi-rewind-circle-fill" style="font-size:1.5em"></i>
                </button>
                <button class="btn2" type="button" onclick="play()" id="pause-replay" disabled>
                    <i class="bi bi-play-circle-fill" id="pause-icon" style="font-size:1.5em"></i>
                </button>
                <button class="btn2" type="button" onclick="fwd()" id="replay-fwd" disabled>
                    <i class="bi bi-fast-forward-circle-fill" style="font-size:1.5em"></i>
                </button>
                <button class="btn2" type="button" onclick="next()" id="replay-next" disabled>
                    <i class="bi bi-skip-forward-circle-fill" style="font-size:1.5em"></i>
                </button>
            </div>
            <!-- Slider -->
            <div class="control-panel-section col-2">
                <input class="speed-slider" style="width:100%" type="range" name="slider" min="1" max="9" value="5" id="speed-slider" />
            </div>
        </div>

        <div class="cardboard">
            <div class="card-table-grid">
                <div></div>
                <div class="replay-cards replay-cards-north">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="ncard0">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="ncard1">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="ncard2">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="ncard3">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="ncard4">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="ncard5">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="ncard6">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="ncard7">
                </div>
                <div></div>

                <div class="replay-cards replay-cards-west">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="wcard0">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="wcard1">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="wcard2">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="wcard3">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="wcard4">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="wcard5">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="wcard6">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="wcard7">
                </div>
                <div class="replay-cardtable-center">

                    <!-- Card Table -->
                    <partial name="_BelotCardTable" />

                </div>
                <div class="replay-cards replay-cards-east">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="ecard0">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="ecard1">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="ecard2">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="ecard3">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="ecard4">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="ecard5">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="ecard6">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="ecard7">
                </div>

                <div></div>
                <div class="replay-cards">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="scard0">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="scard1">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="scard2">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="scard3">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="scard4">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="scard5">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="scard6">
                    <img class="replay-hand-card" src="~/images/Cards/c0-01.png" id="scard7">
                </div>
                <div></div>
            </div>

        </div>
    </div>
</main>

<!-- My Games Offcanvas -->
<div class="offcanvas offcanvas-end parchment2" tabindex="-1" id="my-games">
    <!-- Header -->
    <div class="offcanvas-header">
        <h1>My Games</h1>
        <i class="bi bi-x-lg form-btn" data-bs-dismiss="offcanvas"></i>
    </div>
    <div class="offcanvas-body">
        <!-- Header -->
        <table class="table rounded m-0" id="replay-table">
            <tbody id="replay-table-body"></tbody>
        </table>
    </div>
</div>

<!-- Replay Not Found Modal -->
<div class="modal" id="replay-not-found-modal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Replay load error</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>A replay with the specified id could not be found.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">OK</button>
            </div>
        </div>
    </div>
</div>

